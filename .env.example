# Option A — auto-generate a dev .env (matches docker-compose.yml):
#   npm run env:local
# Option B — copy this file to ".env" and edit.

# Postgres (local: run `npm run docker:up` first, or use Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE"

# Redis (local Redis or Upstash URL)
REDIS_URL="redis://127.0.0.1:6379"

# RS256 keys — run: node scripts/gen-jwt-keys.mjs
# Paste the two lines it prints (they include quotes).
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# Random string, at least 32 characters
JWT_REFRESH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# AES-GCM: 32 bytes and 12 bytes as hex (64 and 24 hex chars)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
ENCRYPTION_IV="0123456789abcdef0123456789"

FRONTEND_URL="http://localhost:5173"

# Optional
# PORT=4000
